    {
      "parameters": {
        "jsCode": "const existingOrderIDs = $('Get Existing Order IDs').all()\n  .map(item => item.json['Order ID']);\n\nconst aliasMap = {};\n$('Read Aliases').all().forEach(r => {\n  if (r.json['Product Name']) aliasMap[r.json['Product Name'].toLowerCase()] = r.json['Recipe Name'];\n});\n\nconst recipeMap = {};\n$('Read Recipes').all().forEach(r => {\n  if (r.json['Name']) recipeMap[r.json['Name']] = {\n    foodCost: Number(r.json['FoodCost']) || 0,\n    batch:    Number(r.json['Batch'])    || 1\n  };\n});\n\nconst seenOrderIDs = new Set();\n\nreturn items.map(item => {\n  const order   = item.json;\n  const product = order.products;\n\n  const placed_date = new Date(order.placed_date).toLocaleDateString('en-US', {\n    month: '2-digit', day: '2-digit', year: 'numeric'\n  }).replace(/\\//g, '-');\n\n  const isFirstRow = !seenOrderIDs.has(order.public_reference);\n  seenOrderIDs.add(order.public_reference);\n\n  const qty        = Number(product.quantity) || 1;\n  const recipeName = aliasMap[product.name.toLowerCase()] || '';\n  const recipe     = recipeName ? recipeMap[recipeName] : null;\n  const foodCost   = recipe ? Math.round((recipe.foodCost / recipe.batch) * qty * 1000) / 1000 : '';\n\n  return {\n    json: {\n      order_id:     order.public_reference,\n      placed_date:  placed_date,\n      product_name: product.name,\n      store:        'Takeaway',\n      qty:          qty,\n      unit_price:   Number(product.amount) || 0,\n      order_total:  isFirstRow ? order.restaurant_total : '',\n      food_cost:    foodCost\n    }\n  };\n}).filter(item => !existingOrderIDs.includes(item.json.order_id));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -4304,
        -400
      ],
