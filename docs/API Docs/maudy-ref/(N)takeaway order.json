    {
      "parameters": {
        "jsCode": "// Skip if no items (empty output from flatten)\nif (!items.length || (items.length === 1 && !items[0].json.order_id)) return [];\n\n// Build alias map\nconst aliasMap = {};\n$('Read Aliases').all().forEach(r => {\n  if (r.json['Product Name']) aliasMap[r.json['Product Name'].toLowerCase()] = r.json['Recipe Name'];\n});\n\n// Build recipe ingredients map: recipeName → [{ ingredient, qty }]\nconst recIngMap = {};\n$('Read Recipe Ingredients').all().forEach(r => {\n  const name = r.json['Recipe Name'] || r.json['Ingredient'] ? null : null;\n  // _RecipeIngredients has: RecipeID, Ingredient, Quantity\n  // We need to match by recipe name via _Recipes\n});\n\n// Build recipeId → name map\nconst recipeIdMap = {};\n$('Read Recipes').all().forEach(r => {\n  if (r.json['RecipeID']) recipeIdMap[String(r.json['RecipeID'])] = r.json['Name'];\n});\n\n// Build recipeName → ingredients\nconst recipeIngByName = {};\n$('Read Recipe Ingredients').all().forEach(r => {\n  const recipeId  = String(r.json['RecipeID']);\n  const recipeName = recipeIdMap[recipeId];\n  if (!recipeName) return;\n  if (!recipeIngByName[recipeName]) recipeIngByName[recipeName] = [];\n  recipeIngByName[recipeName].push({\n    ingredient: r.json['Ingredient'],\n    qty:        Number(r.json['Quantity']) || 0\n  });\n});\n\n// Aggregate deductions per ingredient from all products in this batch\nconst deductions = {}; // ingredient → total qty to deduct\n\nitems.forEach(item => {\n  const productName = (item.json.product_name || '').toLowerCase();\n  const orderedQty  = Number(item.json.qty) || 1;\n  const recipeName  = aliasMap[productName] || '';\n  if (!recipeName) return;\n  const ings = recipeIngByName[recipeName] || [];\n  ings.forEach(ing => {\n    if (!deductions[ing.ingredient]) deductions[ing.ingredient] = 0;\n    deductions[ing.ingredient] += ing.qty * orderedQty;\n  });\n});\n\nif (!Object.keys(deductions).length) return [{ json: { skip: true } }];\n\n// Read current stock and calculate new values\nconst stockRows = $('Read Stock').all();\nconst updates = [];\n\nstockRows.forEach(r => {\n  const ingName = (r.json['Ingredient'] || '').toString().trim();\n  if (!ingName || ingName === 'Donotdelete') return;\n  const deductQty = deductions[ingName];\n  if (!deductQty) return;\n\n  const currentStock = Number(r.json['Current Stock']) || 0;\n  const newStock     = Math.round((currentStock - deductQty) * 1000) / 1000;\n  const minForecast  = Number(r.json['Min Forecast']) || 0;\n  const type         = (r.json['Type'] || '').toLowerCase();\n\n  let actionState = 'Good';\n  if (newStock < minForecast) {\n    actionState = type === 'sauce' ? 'Make Sauce Batch' : 'Need Order';\n  }\n\n  updates.push({ json: {\n    row_number:      r.json['row_number'],\n    'Current Stock': newStock,\n    'Action State':  actionState\n  }});\n});\n\nreturn updates.length ? updates : [{ json: { skip: true } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
